[importlinter]
root_package = stmrr
include_external_packages = True

[importlinter:contract:model-is-qt-free]
name = Model layer must not import Qt or PySide6
type = forbidden
source_modules =
    stmrr.model
forbidden_modules =
    PySide6
    shiboken6

[importlinter:contract:view-does-not-import-model-events]
name = View must not subscribe to model events directly
type = forbidden
source_modules =
    stmrr.view
forbidden_modules =
    stmrr.model.events

[importlinter:contract:projection-is-qt-free]
name = projection.py must not import Qt or PySide6
type = forbidden
source_modules =
    stmrr.view.scene.projection
forbidden_modules =
    PySide6
    shiboken6

[importlinter:contract:blinker-only-in-events]
name = blinker only in events
type = forbidden
source_modules =
    stmrr.model
forbidden_modules =
    blinker
ignore_imports =
    stmrr.model.events -> blinker
allow_indirect_imports = True
